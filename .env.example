# Where the client reads incident data from:
#   unset / "mock" — synchronous read of the seeded deterministic dataset (default)
#   "api"          — fetch from this app's own /api/incidents route
# NEXT_PUBLIC_DATA_SOURCE=api

# When set, the Next.js /api/* route handlers proxy to the FastAPI backend
# (see backend/) instead of serving the local seed. Server-side only — not
# exposed to the browser. Requires the backend running (docker compose up).
# API_BASE_URL=http://localhost:8000
