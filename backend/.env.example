# SQLAlchemy connection string for the PostGIS database.
# docker-compose sets this automatically; override for a local/hosted DB.
DATABASE_URL=postgresql+psycopg://deckwatch:deckwatch@localhost:5432/deckwatch

# Set when running the integration tests (tests/test_api.py):
# TEST_DATABASE_URL=postgresql+psycopg://deckwatch:deckwatch@localhost:5432/deckwatch

# Required by the ingestion pipeline (python -m app.ingest) — the anthropic SDK
# reads this to classify news items with Claude Haiku 4.5.
# ANTHROPIC_API_KEY=sk-ant-...
